# Copy to .env for local testing. Do not commit real values.
MEGAPORT_API_KEY=replace-with-your-api-key
MEGAPORT_API_KEY_SECRET=replace-with-your-api-key-secret
MEGAPORT_AUTH_URL=https://auth-m2m.megaport.com/oauth2/token
MEGAPORT_API_BASE_URL=https://api.megaport.com/v2

# Optional: point at your Opevents CLI if you want live event creation.
OPEVENTS_CLI_PATH=/usr/local/omk/bin/opevents-cli.pl
